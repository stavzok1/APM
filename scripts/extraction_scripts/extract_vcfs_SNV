# 1. Go to your main folder
cd ~/masters/gdc

# 2. Make an output folder for the extracted VCFs
mkdir -p vcfs

# 3. Find every *.vcf.gz and unzip it into vcfs/
find SNV_BRCA_downloads -type f -name '*.vcf.gz' -print0 \
  | while IFS= read -r -d '' f; do
      base=$(basename "${f%.gz}")     # remove only the .gz
      echo "Extracting $f -> vcfs_SNV/$base"
      gunzip -c "$f" > "vcfs_SNV/$base"
    done
